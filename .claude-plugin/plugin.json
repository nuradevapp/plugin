{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "nuradev",
  "displayName": "Nura Dev",
  "version": "2026.07.10",
  "description": "Control your Claude Code session by voice from your phone — nuradev.app",
  "author": { "name": "Nura Dev", "email": "support@nuradev.app" },
  "homepage": "https://nuradev.app",
  "repository": "https://github.com/nuradevapp/plugin",
  "keywords": ["voice", "mobile", "channel", "nuradev"],
  "mcpServers": {
    "nuradev": {
      "command": "bun",
      "args": ["${CLAUDE_PLUGIN_ROOT}/src/index.ts"]
    }
  },
  "channels": [
    {
      "server": "nuradev"
    }
  ],
  "userConfig": {
    "relay_url": {
      "type": "string",
      "title": "Relay URL",
      "description": "WebSocket relay endpoint. Leave empty for wss://relay.nuradev.app — only set this if you run a self-hosted relay."
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=start",
            "timeout": 86400
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=end"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=failure"
          }
        ]
      }
    ],
    "MessageDisplay": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=message"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=stop-failure"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hook.ts --phase=session-end"
          }
        ]
      }
    ]
  }
}
